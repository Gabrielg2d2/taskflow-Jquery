{
  "name": "@taskflow/ui-jquery",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cypress:open": "npm run dev & cypress open --browser chrome",
    "cypress:run:e2e": "ELECTRON_EXTRA_LAUNCH_ARGS='--no-sandbox --disable-dev-shm-usage --disable-gpu' cypress run",
    "cypress:run:e2e:headed": "ELECTRON_EXTRA_LAUNCH_ARGS='--no-sandbox --disable-dev-shm-usage --disable-gpu' cypress run --headed",
    "cypress:run": "start-server-and-test dev http://127.0.0.1:3001 cypress:run:e2e",
    "cypress:run:headed": "start-server-and-test dev http://127.0.0.1:3001 cypress:run:e2e:headed"
  },
  "dependencies": {
    "@design-system/styles": "*",
    "@taskflow/core": "*",
    "@taskflow/infrastructure": "*",
    "jquery": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/cypress": "^10.0.3",
    "cypress": "^15.11.0",
    "start-server-and-test": "^2.0.3",
    "vite": "^7.3.1"
  }
}
