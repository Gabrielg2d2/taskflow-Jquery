{
  "name": "@design-system/styles",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:css",
    "build:css": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && postcss src/styles/input.css -o dist/styles.css --config postcss.config.cjs",
    "dev": "tsup --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "postcss-import": "^16.1.0",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/addon-links": "^8.4.7",
    "@storybook/blocks": "^8.4.7",
    "@storybook/test": "^8.4.7",
    "@storybook/html-vite": "^8.4.7",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "storybook": "^8.4.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
  }
}
