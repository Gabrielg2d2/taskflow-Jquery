{
  "name": "@taskflow/ui-react",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cypress:open": "ELECTRON_EXTRA_LAUNCH_ARGS='--no-sandbox --disable-dev-shm-usage --disable-gpu' cypress open",
    "cypress:run": "start-server-and-test dev http://localhost:3002 cypress:run:e2e",
    "cypress:run:e2e": "ELECTRON_EXTRA_LAUNCH_ARGS='--no-sandbox --disable-dev-shm-usage --disable-gpu' cypress run",
    "cypress:run:headed": "start-server-and-test dev http://localhost:3002 cypress:run:e2e:headed",
    "cypress:run:e2e:headed": "cypress run --headed"
  },
  "dependencies": {
    "@taskflow/core": "*",
    "@taskflow/infrastructure": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/cypress": "^10.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "cypress": "^13.15.2",
    "start-server-and-test": "^2.0.3",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
