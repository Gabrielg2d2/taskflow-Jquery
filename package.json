{
  "name": "taskflow-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:jquery",
    "dev:jquery": "npm run dev --workspace=@taskflow/ui-jquery",
    "dev:react": "npm run dev --workspace=@taskflow/ui-react",
    "dev:all": "npm run dev:jquery & npm run dev:react",
    "build": "npm run build --workspaces --if-present",
    "build:jquery": "npm run build --workspace=@taskflow/ui-jquery",
    "build:react": "npm run build --workspace=@taskflow/ui-react",
    "test:core": "npm test --workspace=@taskflow/core",
    "test:infra": "npm test --workspace=@taskflow/infrastructure",
    "test:jquery": "npm test --workspace=@taskflow/ui-jquery",
    "test:react": "npm test --workspace=@taskflow/ui-react",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "test:wc": "vitest watch --coverage",
    "cypress:open:jquery": "npm run cypress:open --workspace=@taskflow/ui-jquery",
    "cypress:open:react": "npm run cypress:open --workspace=@taskflow/ui-react",
    "cypress:run:jquery": "npm run cypress:run --workspace=@taskflow/ui-jquery",
    "cypress:run:react": "npm run cypress:run --workspace=@taskflow/ui-react",
    "build:design-system": "npm run build --workspace=@taskflow/design-system",
    "storybook:design-system": "npm run storybook --workspace=@taskflow/design-system"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18"
  }
}
